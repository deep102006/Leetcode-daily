class Solution {
public:
    vector<bool> kidsWithCandies(vector<int>& candies, int extraCandies) {
        int maxcan=candies[0];
        for(int i:candies){
            maxcan=max(maxcan,i);
        }
        vector<bool>arr(candies.size(),0);
        for(int i=0;i<candies.size();i++){
            if(candies[i]+extraCandies>=maxcan){
                arr[i]=true;
            }else{
                arr[i]=false;
            }
        }
        return arr;
    }
};
